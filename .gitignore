# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# claude code: .claude/settings.json e .claude/skills/ agora são RASTREADOS no origin
# (pros agentes cloud enxergarem as skills do Bombardier) e removidos do mirror design2
# por scripts/sync-design2.sh. Aqui ficam só os arquivos de máquina:
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# local agent skill cache (personal — do not share)
.agents/
skills-lock.json

# local cursor settings (personal)
.cursor/settings.json
.cursor/rules/

# Docs de contexto do agente (AGENTS.md, CLAUDE.md, BOMBARDIER.md, AWSALES_CONTEXT.md), o MCP de
# projeto (.mcp.json), o scripts/sync-design2.sh e as rules migradas do Cursor
# (docs/cursor-rules/) são RASTREADOS no origin e removidos do mirror design2 pelo
# script de sync — NÃO ignore aqui. A STRIP list canônica vive em
# scripts/sync-design2.sh:PRIVATE_PATHS.

# next.js
/.next/
# per-user build caches (NEXT_DIST_DIR), e.g. .next-germano
/.next-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# local uploads (max 1GB for preview testing)
/storage

# bombardier project storage (filesystem-saved projects are user data)
/bombardier/projects/*
!/bombardier/projects/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts

# local backups
*.bak

# review bridge runtime state (grows unbounded — not source code)
review-bridge/data/*.json
review-bridge/data/.backups/
review-bridge/node_modules/

# flow-bridge runtime state (grows unbounded — not source code)
flow-bridge/data/*.json
flow-bridge/node_modules/

# page-editor runtime state — Live Edit Mode persisted edits (not source code)
page-editor/data/*.json

# Playwright MCP verification artifacts (snapshots/console logs)
.playwright-mcp/

# Local session captures (screenshots + cap JSON refs — not product source)
/g-*.png
/cap-*.json
/germano-perfil.png
/usado-card.png
