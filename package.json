  "description": "AwSales — plataforma de agentes de IA para vendas. Construída com o método Bombardier (design system + telas + fluxos via /bombardier/styleguide).",
  "scripts": {
    "dev": "next dev",
    "dev:lan": "DEV_LAN=1 next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "bridge": "npm --prefix bridge start",
    "bridge:dev": "npm --prefix bridge run dev",
    "bridge:install": "npm --prefix bridge install",
    "edit-bridge": "npm --prefix bridge-edit start",
    "edit-bridge:dev": "npm --prefix bridge-edit run dev",
    "edit-bridge:install": "npm --prefix bridge-edit install"
  },
