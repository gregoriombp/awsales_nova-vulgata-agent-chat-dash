{
  "name": "bombardier-review-bridge",
  "version": "0.2.0",
  "private": true,
  "description": "Servidor local pra sincronizar comentários do Bombardier Review Mode entre revisores na mesma LAN. SSE + POST, lowdb em arquivo, auth por token compartilhado.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx watch --env-file=.env src/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lowdb": "^7.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
