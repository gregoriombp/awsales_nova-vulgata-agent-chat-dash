# Token compartilhado entre frontend (NEXT_PUBLIC_BOMBARDIER_REVIEW_TOKEN)
# e este servidor. Sem token configurado, o bridge rejeita todo request.
# Use algo aleatório longo (ex.: openssl rand -hex 32).
BOMBARDIER_REVIEW_TOKEN=

# Porta do servidor. Default 9878.
# BOMBARDIER_REVIEW_PORT=9878

# Host de bind. Default 0.0.0.0 (LAN). Use 127.0.0.1 pra travar só na máquina.
# BOMBARDIER_REVIEW_HOST=0.0.0.0
