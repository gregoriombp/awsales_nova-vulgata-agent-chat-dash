# Copy to .env.local and fill in. Anything prefixed with NEXT_PUBLIC_ ships to
# the client — keep secrets out of NEXT_PUBLIC_ vars.

# Claude Edit overlay (floating copilot at /:9877). Off by default.
# NEXT_PUBLIC_CLAUDE_EDIT_ENABLED=true

# Bombardier Review Mode — overlay de anotação colaborativa (free-draw + pin).
# v1 grava no localStorage. Documentação: /bombardier/styleguide/foundation/review-mode
 NEXT_PUBLIC_BOMBARDIER_REVIEW_ENABLED=true
NEXT_PUBLIC_BOMBARDIER_REVIEW_ENABLED=true

# Review Mode v2 — bridge local (LAN-only) pra sincronizar comentários entre
# revisores. Setar AMBOS NEXT_PUBLIC_BOMBARDIER_REVIEW_BRIDGE_URL e
# NEXT_PUBLIC_BOMBARDIER_REVIEW_TOKEN faz o frontend usar o bridge no lugar
# do localStorage. Apague as duas vars pra voltar pro modo local.
#
# Subir o servidor:
#   cd review-bridge && npm install
#   echo "BOMBARDIER_REVIEW_TOKEN=<token-igual-ao-do-frontend>" > review-bridge/.env
#   npm run review-bridge:dev   # roda na porta 9878 em 0.0.0.0 (LAN)
#
 NEXT_PUBLIC_BOMBARDIER_REVIEW_BRIDGE_URL=http://192.168.0.10:9878
 NEXT_PUBLIC_BOMBARDIER_REVIEW_TOKEN=cole-um-segredo-grande-aleatorio
 
